{
  "schema_version": "xrtm.workflow.v1",
  "name": "metaculus-cup-dryrun",
  "title": "Metaculus Cup dry-run workflow",
  "description": "Prepare a reviewable dry-run competition submission bundle on top of the flagship benchmark graph without attempting live submission.",
  "workflow_kind": "competition",
  "questions": {
    "source": "real-binary-corpus",
    "corpus_id": "xrtm-real-binary-v1",
    "limit": 5
  },
  "runtime": {
    "provider": "mock",
    "max_tokens": 768
  },
  "graph": {
    "entry": "load_questions",
    "nodes": {
      "load_questions": {
        "kind": "tool",
        "implementation": "xrtm.product.workflow_nodes.load_questions_node",
        "description": "Load the released dry-run competition question slice."
      },
      "question_context": {
        "kind": "tool",
        "implementation": "xrtm.product.workflow_nodes.question_context_node",
        "description": "Extract question context for downstream nodes."
      },
      "runtime_router": {
        "kind": "router",
        "implementation": "xrtm.product.workflow_nodes.runtime_router_node",
        "description": "Choose the real-runtime or provider-free competition branch.",
        "config": {
          "preferred_route": "real",
          "fallback_route": "fallback",
          "require_healthy": true
        }
      },
      "primary_candidate": {
        "kind": "model",
        "implementation": "xrtm.product.workflow_nodes.candidate_forecast_node",
        "runtime": "local-openai-compatible",
        "description": "Run the primary model-backed competition candidate.",
        "config": {
          "provider": "local-llm"
        }
      },
      "provider_free_control": {
        "kind": "model",
        "implementation": "xrtm.product.workflow_nodes.provider_free_candidate_node",
        "runtime": "provider-free-demo",
        "description": "Run the deterministic provider-free competition control."
      },
      "time_series_baseline": {
        "kind": "model",
        "implementation": "xrtm.product.workflow_nodes.time_series_baseline_node",
        "runtime": "time-series-baseline",
        "description": "Run the deterministic non-LLM competition baseline candidate."
      },
      "aggregate_candidates": {
        "kind": "aggregator",
        "implementation": "xrtm.product.workflow_nodes.aggregate_candidate_forecasts_node",
        "description": "Combine the heterogeneous candidate forecasts into the official competition records.",
        "config": {
          "strategy": "weighted-mean",
          "weights": {
            "primary_candidate": 0.6,
            "provider_free_control": 0.25,
            "time_series_baseline": 0.15
          }
        }
      },
      "score": {
        "kind": "scorer",
        "implementation": "xrtm.product.workflow_nodes.score_node",
        "description": "Score the dry-run outputs against the offline benchmark slice."
      },
      "backtest": {
        "kind": "scorer",
        "implementation": "xrtm.product.workflow_nodes.backtest_node",
        "description": "Write backtest evidence for the dry-run bundle."
      },
      "review_gate": {
        "kind": "human-gate",
        "implementation": "xrtm.product.workflow_nodes.human_gate_placeholder_node",
        "description": "Pause for manual review before preparing the dry-run bundle.",
        "config": {
          "prompt": "Review the dry-run competition forecasts before exporting the submission bundle."
        }
      },
      "prepare_submission": {
        "kind": "tool",
        "implementation": "xrtm.product.workflow_nodes.competition_submission_node",
        "description": "Write the redacted dry-run competition submission bundle.",
        "config": {
          "competition_pack": "metaculus-cup",
          "artifact_name": "competition_submission.json",
          "transport": {
            "method": "manual-upload",
            "notes": "Dry-run only. Review the bundle and submit manually outside XRTM if policy allows.",
            "token": "${METACULUS_TOKEN}"
          }
        }
      },
      "report": {
        "kind": "tool",
        "implementation": "xrtm.product.workflow_nodes.report_node",
        "description": "Render the competition dry-run report."
      }
    },
    "edges": [
      {
        "from_node": "load_questions",
        "to_node": "question_context"
      },
      {
        "from_node": "question_context",
        "to_node": "runtime_router"
      },
      {
        "from_node": "real_fanout",
        "to_node": "aggregate_candidates"
      },
      {
        "from_node": "fallback_fanout",
        "to_node": "aggregate_candidates"
      },
      {
        "from_node": "aggregate_candidates",
        "to_node": "score"
      },
      {
        "from_node": "score",
        "to_node": "backtest"
      },
      {
        "from_node": "backtest",
        "to_node": "review_gate"
      },
      {
        "from_node": "review_gate",
        "to_node": "prepare_submission"
      },
      {
        "from_node": "prepare_submission",
        "to_node": "report"
      }
    ],
    "parallel_groups": {
      "real_fanout": {
        "nodes": [
          "primary_candidate",
          "provider_free_control",
          "time_series_baseline"
        ]
      },
      "fallback_fanout": {
        "nodes": [
          "provider_free_control",
          "time_series_baseline"
        ]
      }
    },
    "conditional_routes": {
      "runtime_router": {
        "route_field": "route",
        "routes": {
          "real": "real_fanout",
          "fallback": "fallback_fanout"
        }
      }
    }
  },
  "artifacts": {
    "write_report": true,
    "write_blueprint_copy": true,
    "write_graph_trace": true
  },
  "scoring": {
    "write_eval": true,
    "write_train_backtest": true
  },
  "tags": [
    "next-release",
    "competition",
    "dry-run"
  ]
}
